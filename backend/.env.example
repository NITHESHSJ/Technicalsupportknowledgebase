# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/dbname

# CORS Configuration
# For development: use http://localhost:3000 or http://localhost:5173
# For production: use your deployed domain (e.g., https://yourdomain.com)
# For multiple domains: use comma-separated list (e.g., http://localhost:3000,https://yourdomain.com)
CORS_ORIGIN=http://localhost:5173

# JWT Configuration (optional)
JWT_SECRET=your_jwt_secret_key_here
